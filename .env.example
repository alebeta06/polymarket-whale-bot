# ========================================
# POLYMARKET API CREDENTIALS
# ========================================
# Get these from: https://polymarket.com/settings?tab=builder#
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_passphrase_here

# ========================================
# WALLET CONFIGURATION
# ========================================
# Your Phantom wallet private key (NEVER share this!)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your EOA address (Phantom Polygon address)
EOA_ADDRESS=0xYOUR_EOA_ADDRESS_HERE

# Your Polymarket Proxy Wallet address
PROXY_WALLET_ADDRESS=0xYOUR_PROXY_WALLET_HERE

# ========================================
# BLOCKCHAIN RPC
# ========================================
# Polygon RPC endpoint
POLYGON_RPC_URL=https://polygon-rpc.com

# ========================================
# BOT CONFIGURATION
# ========================================
# Trading mode: true = Paper Trading (simulation), false = Real trading
DRY_RUN=true

# Maximum percentage of balance to use per trade (0.15 = 15%)
MAX_POSITION_SIZE_PERCENT=0.15

# Daily stop-loss percentage (0.10 = 10%)
DAILY_STOP_LOSS_PERCENT=0.10

# Minimum profit percentage to execute a trade (0.02 = 2%)
MIN_PROFIT_PERCENT=0.02

# Polymarket fee percentage (currently 2%)
POLYMARKET_FEE_PERCENT=0.02

# ========================================
# WHALE GATING & PAPER TRADING
# ========================================
# Ignore whale trades whose USD notional is below this (dust filter)
MIN_WHALE_TRADE_USD=500

# Skip whale trades older than this (seconds) — price has moved, copy is stale
MAX_WHALE_TRADE_AGE_SECONDS=600

# Notional bankroll used for paper-trading sizing (does NOT affect real trading)
PAPER_STARTING_BALANCE_USD=1000

# Hard cap per single copy trade in USD
MAX_PER_COPY_TRADE_USD=200

# Run reconcile every N completed poll cycles (0 disables in-loop reconciling).
# Default 10 cycles × 60s = every 10 min.
RECONCILE_EVERY_N_POLLS=10

# ========================================
# MARKET SCANNER SETTINGS
# ========================================
# Minimum volume to consider a market (in USDC)
MIN_MARKET_VOLUME=10000

# Categories to scan (comma-separated)
SCAN_CATEGORIES=Politics,Crypto,Sports

# How often to refresh market data (seconds)
MARKET_REFRESH_INTERVAL=300

# ========================================
# WEBSOCKET SETTINGS
# ========================================
# WebSocket URL for real-time updates
WEBSOCKET_URL=wss://ws-subscriptions-clob.polymarket.com

# Enable WebSocket for real-time price updates
USE_WEBSOCKET=true

# ========================================
# LOGGING
# ========================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file rotation (MB)
LOG_MAX_SIZE=100

# ========================================
# MONITORING & ALERTS
# ========================================
# Enable Telegram notifications (optional)
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ========================================
# ADVANCED SETTINGS
# ========================================
# Rate limit buffer (percentage of max rate to use)
RATE_LIMIT_BUFFER=0.8

# Use Relayer for gasless transactions
USE_RELAYER=false

# Order batch size (max 5 per Polymarket)
ORDER_BATCH_SIZE=5
